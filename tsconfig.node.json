{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "server/**/*.ts",
    "src/lib/sandbox-store.ts",
    "src/types/**/*.ts",
    "src/mock/action-map.ts",
    "src/mock/knowledge-base.ts",
    "src/mock/tickets.ts"
  ]
}
